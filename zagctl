#!/usr/bin/env bash
# zagctl — thin launcher for native zagpa agent/MCP (no Python).
set -e
ROOT="$(cd "$(dirname "$0")" && pwd)"
ZAGPA="$ROOT/zagpa"
if [ ! -x "$ZAGPA" ]; then
    echo "zagctl: zagpa not found — run ./build.sh" >&2
    exit 1
fi

cmd="${1:-help}"
shift || true

mutate() {
    key="${TRITON_IDEMPOTENCY:-zagctl-$$-$RANDOM}"
    exec "$ZAGPA" --agent --once "request $key current $*"
}

case "$cmd" in
    repl)
        exec "$ZAGPA" --agent
        ;;
    mcp)
        exec "$ZAGPA" --mcp
        ;;
    run)
        exec "$ZAGPA" --agent "$1"
        ;;
    do)
        shift || true
        printf '%s\n' "$@" | "$ZAGPA" --agent
        ;;
    cmd)
        exec "$ZAGPA" --agent --once "$*"
        ;;
    demo|new)
        mutate "$cmd $*"
        ;;
    ping|help|list|list_files|status|coords|power|perf|kinds|build)
        exec "$ZAGPA" --agent --once "$cmd $*"
        ;;
    place)
        mutate "place $1 $2 $3 $4 ${5:-0}"
        ;;
    route)
        mutate "route $1 $2 $3 $4"
        ;;
    delete|del)
        mutate "delete $1"
        ;;
    undo|redo)
        mutate "$cmd"
        ;;
    open)
        mutate "open $1"
        ;;
    save)
        mutate "save $1"
        ;;
    render)
        exec "$ZAGPA" --agent --once "render $1"
        ;;
    export)
        exec "$ZAGPA" --agent --once "export $1"
        ;;
    sim)
        if [ "$1" = "step" ]; then
            exec "$ZAGPA" --agent --once "sim step ${2:-1}"
        fi
        exec "$ZAGPA" --agent --once "sim $1"
        ;;
    flash)
        if [ "${1:-}" = "import" ]; then
            mutate "flash $*"
        fi
        exec "$ZAGPA" --agent --once "flash $*"
        ;;
    test)
        exec "$ZAGPA" --agent --once "test $1"
        ;;
    *)
        exec "$ZAGPA" --agent --once "$cmd $*"
        ;;
esac
