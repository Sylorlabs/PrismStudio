// gpu_fill_test.zag — capability test for the GPU parallel buffer clear.
// Opens a GPU compute session, fills a 16384-dword GTT buffer with a solid
// color on the shader cores (gpu_fill_u32), and verifies every dword on the
// CPU. Skips cleanly (exit 0) when no render node is present.
@import("../std/list.zag") as list
@import("../src/gpu_rt.zag")
@import("../src/gpu_compute.zag")

extern fn _zag_memcpy(dst: *i8, src: *i8, n: i32) void;

fn read_u32(cpu_addr: i64, off: i32) i64 {
    let b: list.ArrayList[u8] = list.make[u8](4);
    let i: i32 = 0;
    while (i < 4) { list.push[u8](&b, 0); i = i + 1; }
    _zag_memcpy(b.data as *i8, (cpu_addr + (off as i64)) as *i8, 4);
    let v: i64 = 0;
    let k: i32 = 0;
    while (k < 4) { v = v + (b.data[k] as i64) * pow2(k * 8); k = k + 1; }
    list.free[u8](&b);
    return v;
}

fn main() i32 {
    let pixels: i64 = 1024;   // small: large grids are intermittently unstable
    let color: i64 = 0x11223344;

    let c: GpuCompute = gpu_compute_open();
    if (!c.ok) { _zag_println("gpu: no render node / setup failed (skipping)"); return 0; }

    let data: GpuBuf = gpu_alloc(&c.g, pixels * 4);
    let mapped: bool = gpu_map_data(&c.g, &data);
    if (!data.ok || !mapped) { _zag_println("  XX  buffer alloc/map failed"); gpu_compute_close(&c); return 1; }

    // poison so only the shader can produce the fill color
    let poison: list.ArrayList[u8] = list.make[u8](4096);
    let pi: i32 = 0;
    while (pi < 4096) { list.push[u8](&poison, 238); pi = pi + 1; }
    let off: i32 = 0;
    while ((off as i64) < pixels * 4) {
        _zag_memcpy((data.cpu_addr + (off as i64)) as *i8, poison.data as *i8, 4096);
        off = off + 4096;
    }
    list.free[u8](&poison);

    let ok: bool = gpu_fill_u32(&c.g, c.ctx, &data, &c.shader, &c.ib, color, pixels);

    let fails: i32 = 0;
    if (!ok) { _zag_println("  XX  dispatch/fence failed"); fails = fails + 1; }
    let bad: i32 = 0;
    let i: i32 = 0;
    while (i < (pixels as i32)) {
        if (read_u32(data.cpu_addr, i * 4) != color) { bad = bad + 1; }
        i = i + 1;
    }
    if (bad == 0) {
        _zag_print("  ok  ");
        _zag_print(_zag_i64_to_str(pixels));
        _zag_println(" dwords filled on the shader cores, verified");
    } else {
        _zag_print("  XX  "); _zag_print(_zag_i64_to_str(bad as i64)); _zag_println(" dwords wrong");
        fails = fails + 1;
    }

    gpu_free(&c.g, &data);
    gpu_compute_close(&c);
    if (fails == 0) { _zag_println("GPU FILL TEST: ALL PASS"); return 0; }
    _zag_println("GPU FILL TEST: FAILURES"); return 1;
}
