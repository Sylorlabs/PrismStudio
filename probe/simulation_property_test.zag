@import("../std/list.zag") as list
@import("../std/hashmap.zag") as hm
@import("../src/flash_ir.zag")
@import("../src/editops.zag")
@import("../src/sim_region.zag")

fn check(name_: []u8, ok: bool, failures: *i32) void {
    if (ok) { _zag_print("  ok  "); } else { _zag_print("  XX  "); failures.* = failures.* + 1; }
    _zag_println(name_);
}

fn oracle(op: i32, a: i32, b: i32) i32 {
    if (op == 2) { return 0 - a; }
    if (op == 5) { return a * b; }
    if (op == 7) { let v: i32 = a; if (b < v) { v = b; } return 0 - v; }
    let raw: i32 = a + b;
    if (raw > 1) { raw = raw - 3; }
    if (raw < 0 - 1) { raw = raw + 3; }
    return raw;
}

fn sim_state_equal(a: *Sim, b: *Sim) bool {
    if (a.*.symbol != b.*.symbol || a.*.nodes.len != b.*.nodes.len ||
        a.*.sguides.len != b.*.sguides.len || a.*.clock_ghz != b.*.clock_ghz) { return false; }
    let i: i32 = 0;
    while (i < a.*.nodes.len) {
        let an: SNode = a.*.nodes.data[i];
        let bi: i32 = sim_node_index(b, an.comp_id);
        if (bi < 0) { return false; }
        let bn: SNode = b.*.nodes.data[bi];
        if (an.kind != bn.kind || an.soh != bn.soh || an.out_t != bn.out_t ||
            an.prev_t != bn.prev_t || an.in_sum != bn.in_sum || an.in_a != bn.in_a ||
            an.in_b != bn.in_b || an.logic_op != bn.logic_op || an.hist.len != bn.hist.len) { return false; }
        let hi: i32 = 0;
        while (hi < an.hist.len) { if (an.hist.data[hi] != bn.hist.data[hi]) { return false; } hi = hi + 1; }
        i = i + 1;
    }
    let gi: i32 = 0;
    while (gi < a.*.sguides.len) {
        let ag: SGuide = a.*.sguides.data[gi];
        let bj: i32 = sim_find_in(b.*.sguides, ag.guide_id);
        if (bj < 0) { return false; }
        let bg: SGuide = b.*.sguides.data[bj];
        if (ag.delay != bg.delay || ag.head != bg.head || ag.arrived != bg.arrived || ag.ring.len != bg.ring.len) { return false; }
        let ri: i32 = 0;
        while (ri < ag.ring.len) { if (ag.ring.data[ri] != bg.ring.data[ri]) { return false; } ri = ri + 1; }
        gi = gi + 1;
    }
    return true;
}

fn build_test_network(dx: i32, dz: i32) *Scene {
    let s: *Scene = scene_new();
    let p: i32 = scene_place(s, Kind.Plate, vox(dx, 0, dz), 0);
    let e: i32 = scene_place(s, Kind.Emitter, vox(dx + 1, 1, dz + 2), 0);
    let c: i32 = scene_place(s, Kind.Chamber, vox(dx + 4, 1, dz + 3), 0);
    let d: i32 = scene_place(s, Kind.Detector, vox(dx + 7, 1, dz + 4), 0);
    if (p > 0 && e > 0 && c > 0 && d > 0) {
        let _r1: bool = flash_route(s, e, 0, c, 0);
        let _r2: bool = flash_route(s, c, 3, d, 0);
    }
    return s;
}

fn run_steps(sim: *Sim, s: *Scene, count: i32) void {
    sim_recompile(sim, s);
    let i: i32 = 0;
    while (i < count) { sim_step(sim, s); i = i + 1; }
}

fn main() i32 {
    let failures: i32 = 0;
    check("unknown glyph", _zag_strcmp(trit_glyph(signal_unknown()), "?") == 1, &failures);
    check("high-Z glyph", _zag_strcmp(trit_glyph(signal_high_z()), "Z") == 1, &failures);
    check("error propagates", trit_sat_add(signal_unknown(), 1) == signal_error(), &failures);

    let ops: list.ArrayList[i32] = list.make[i32](4);
    list.push[i32](&ops, 2); list.push[i32](&ops, 3); list.push[i32](&ops, 5); list.push[i32](&ops, 7);
    let truth_ok: bool = true;
    let oi: i32 = 0;
    while (oi < ops.len) {
        let a: i32 = 0 - 1;
        while (a <= 1) {
            let b: i32 = 0 - 1;
            while (b <= 1) {
                if (flash_logic_expected(ops.data[oi], a, b) != oracle(ops.data[oi], a, b)) { truth_ok = false; }
                b = b + 1;
            }
            a = a + 1;
        }
        oi = oi + 1;
    }
    check("exhaustive Flash trit truth tables", truth_ok, &failures);

    let s: *Scene = scene_new();
    let d1: f64 = guide_delay_fs_for(s, 1000.0);
    let d2: f64 = guide_delay_fs_for(s, 2000.0);
    check("propagation delay linear in length", d2 > d1 && d2 == d1 * 2.0, &failures);
    let slow: i32 = guide_delay_symbols_for_model(s, 50.0, 10000000.0);
    let fast: i32 = guide_delay_symbols_for_model(s, 100.0, 10000000.0);
    check("higher symbol rate requires at least as many delay symbols", fast >= slow, &failures);

    let sim: *Sim = sim_new();
    s.*.model.group_index.known = false;
    sim.*.mode = SimMode.Physical; sim_recompile(sim, s);
    check("physical mode rejects incomplete model", !sim.*.model_ok, &failures);
    sim.*.mode = SimMode.Functional; sim_recompile(sim, s);
    check("functional mode is independent of physical completeness", sim.*.model_ok, &failures);

    let ds: *Scene = scene_new();
    let dp: i32 = scene_place(ds, Kind.Plate, vox(0, 0, 0), 0);
    let de: i32 = scene_place(ds, Kind.Emitter, vox(1, 1, 2), 0);
    let dc: i32 = scene_place(ds, Kind.Chamber, vox(4, 1, 3), 0);
    let dd: i32 = scene_place(ds, Kind.Detector, vox(7, 1, 4), 0);
    let built: bool = dp > 0 && de > 0 && dc > 0 && dd > 0 &&
        flash_route(ds, de, 0, dc, 0) && flash_route(ds, dc, 3, dd, 0);
    let inc: *Sim = sim_new();
    sim_recompile_region(inc, ds);
    let warm: i32 = 0;
    while (warm < 8) { sim_step(inc, ds); warm = warm + 1; }
    let isolated: i32 = scene_place(ds, Kind.Plate, vox(500, 0, 500), 0);
    sim_recompile_region(inc, ds);
    let saved: bool = design_save(ds, "/tmp/triton_sim_differential.zpa");
    let fs: *Scene = scene_new();
    let reloaded: bool = design_load(fs, "/tmp/triton_sim_differential.zpa");
    let full: *Sim = sim_new();
    sim_recompile(full, fs);
    warm = 0;
    while (warm < 8) { sim_step(full, fs); warm = warm + 1; }
    check("incremental/full setup valid", built && isolated > 0 && saved && reloaded, &failures);
    check("incremental equals full after benign topology edit", sim_state_equal(inc, full), &failures);
    let more: i32 = 0;
    while (more < 24) { sim_step(inc, ds); sim_step(full, fs); more = more + 1; }
    check("incremental/full remain equal after stepping", sim_state_equal(inc, full), &failures);

    let trans_a: *Scene = build_test_network(0, 0);
    let trans_b: *Scene = build_test_network(100, 100);
    let trans_sa: *Sim = sim_new(); let trans_sb: *Sim = sim_new();
    run_steps(trans_sa, trans_a, 32); run_steps(trans_sb, trans_b, 32);
    check("translation preserves photonic simulation", sim_state_equal(trans_sa, trans_sb), &failures);

    let eq_a: *Scene = build_test_network(0, 0);
    let eq_b: *Scene = build_test_network(0, 0);
    let alt_ok: bool = eq_b.*.guides.len > 0 && eq_b.*.guides.data[0].path.len == 3;
    if (alt_ok) {
        let g: *Guide = &eq_b.*.guides.data[0];
        let st: Vox = g.*.path.data[0]; let en: Vox = g.*.path.data[2];
        if (g.*.path.data[1].x == st.x) { g.*.path.data[1] = vox(en.x, st.y, st.z); }
        else { g.*.path.data[1] = vox(st.x, st.y, en.z); }
    }
    let eq_sa: *Sim = sim_new(); let eq_sb: *Sim = sim_new();
    run_steps(eq_sa, eq_a, 32); run_steps(eq_sb, eq_b, 32);
    check("equivalent shortest routing preserves simulation",
        alt_ok && scene_validation_errors(eq_b) == 0 && sim_state_equal(eq_sa, eq_sb), &failures);

    check("metamorphic fixture saves", design_save(eq_a, "/tmp/triton_metamorphic.zpa"), &failures);
    let ser: *Scene = scene_new();
    let ser_ok: bool = design_load(ser, "/tmp/triton_metamorphic.zpa");
    let ser_sim: *Sim = sim_new(); run_steps(ser_sim, ser, 32);
    check("benign serialization preserves simulation", ser_ok && sim_state_equal(eq_sa, ser_sim), &failures);

    if (failures == 0) { _zag_println("SIMULATION PROPERTIES: ALL PASS"); return 0; }
    _zag_println("SIMULATION PROPERTIES: FAILURES"); return 1;
}
